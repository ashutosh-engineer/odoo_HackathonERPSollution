<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <!-- Stock ledger: everyone reads, no one writes via ORM (write is blocked in Python) -->
    <record id="rule_stock_ledger_all_read" model="ir.rule">
        <field name="name">Stock Ledger: All Users Read</field>
        <field name="model_id" ref="shiv_inventory.model_shiv_stock_ledger"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_viewer'))]"/>
        <field name="perm_read">1</field><field name="perm_write">0</field>
        <field name="perm_create">0</field><field name="perm_unlink">0</field>
    </record>
    <!-- Stock adjustments: warehouse staff only see their own -->
    <record id="rule_stock_adj_own" model="ir.rule">
        <field name="name">Stock Adjustment: Warehouse User Sees Own</field>
        <field name="model_id" ref="shiv_inventory.model_shiv_stock_adjustment"/>
        <field name="domain_force">[('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_warehouse_user'))]"/>
        <field name="perm_read">1</field><field name="perm_write">1</field>
        <field name="perm_create">1</field><field name="perm_unlink">0</field>
    </record>
    <!-- Managers see all adjustments -->
    <record id="rule_stock_adj_manager_all" model="ir.rule">
        <field name="name">Stock Adjustment: Manager Sees All</field>
        <field name="model_id" ref="shiv_inventory.model_shiv_stock_adjustment"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_warehouse_manager'))]"/>
        <field name="perm_read">1</field><field name="perm_write">1</field>
        <field name="perm_create">1</field><field name="perm_unlink">0</field>
    </record>
</data></odoo>
