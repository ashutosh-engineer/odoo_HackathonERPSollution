<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">

    <!-- MO sequence -->
    <record id="seq_shiv_mo" model="ir.sequence">
        <field name="name">Shiv Manufacturing Order</field>
        <field name="code">shiv.manufacturing.order</field>
        <field name="prefix">MO-</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
    </record>

    <!-- Default Work Centers -->
    <record id="wc_carpentry" model="shiv.work.center">
        <field name="name">Carpentry</field>
        <field name="code">WC-CARP</field>
        <field name="capacity">20</field>
    </record>
    <record id="wc_upholstery" model="shiv.work.center">
        <field name="name">Upholstery</field>
        <field name="code">WC-UPHO</field>
        <field name="capacity">15</field>
    </record>
    <record id="wc_finishing" model="shiv.work.center">
        <field name="name">Finishing &amp; Polish</field>
        <field name="code">WC-FINI</field>
        <field name="capacity">30</field>
    </record>
    <record id="wc_assembly" model="shiv.work.center">
        <field name="name">Final Assembly</field>
        <field name="code">WC-ASSY</field>
        <field name="capacity">25</field>
    </record>
    <record id="wc_qc" model="shiv.work.center">
        <field name="name">Quality Control</field>
        <field name="code">WC-QC</field>
        <field name="capacity">50</field>
    </record>

</data></odoo>
