<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <record id="rule_mo_prod_user_assigned" model="ir.rule">
        <field name="name">MO: Production User Sees Assigned + Draft</field>
        <field name="model_id" ref="shiv_manufacturing.model_shiv_manufacturing_order"/>
        <field name="domain_force">[('state','in',['draft','confirmed','in_progress'])]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_production_user'))]"/>
        <field name="perm_read">1</field><field name="perm_write">1</field>
        <field name="perm_create">0</field><field name="perm_unlink">0</field>
    </record>
    <record id="rule_mo_prod_manager_all" model="ir.rule">
        <field name="name">MO: Production Manager Sees All</field>
        <field name="model_id" ref="shiv_manufacturing.model_shiv_manufacturing_order"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_production_manager'))]"/>
        <field name="perm_read">1</field><field name="perm_write">1</field>
        <field name="perm_create">1</field><field name="perm_unlink">0</field>
    </record>
</data></odoo>
