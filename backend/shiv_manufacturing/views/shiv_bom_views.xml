<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <!-- BoM LIST -->
    <record id="view_shiv_bom_list" model="ir.ui.view">
        <field name="name">shiv.bom.list</field>
        <field name="model">shiv.bom</field>
        <field name="arch" type="xml">
            <tree string="Bills of Materials"
                  decoration-muted="not is_active">
                <field name="product_id"/>
                <field name="qty_produced"/>
                <field name="version"/>
                <field name="is_active" widget="boolean"/>
                <field name="notes" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- BoM FORM -->
    <record id="view_shiv_bom_form" model="ir.ui.view">
        <field name="name">shiv.bom.form</field>
        <field name="model">shiv.bom</field>
        <field name="arch" type="xml">
            <form string="Bill of Materials">
                <sheet>
                    <group>
                        <group string="Finished Product">
                            <field name="product_id"/>
                            <field name="qty_produced"/>
                            <field name="version"/>
                            <field name="is_active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Components">
                            <field name="component_ids" widget="one2many">
                                <tree editable="bottom">
                                    <field name="product_id" string="Component"/>
                                    <field name="qty_required"/>
                                    <field name="uom_id"/>
                                    <field name="notes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_shiv_bom" model="ir.actions.act_window">
        <field name="name">Bills of Materials</field>
        <field name="res_model">shiv.bom</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_active': True}</field>
    </record>

</data></odoo>
