<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <!-- MO LIST -->
    <record id="view_shiv_mo_list" model="ir.ui.view">
        <field name="name">shiv.manufacturing.order.list</field>
        <field name="model">shiv.manufacturing.order</field>
        <field name="arch" type="xml">
            <list string="Manufacturing Orders"
                  decoration-success="state == 'done'"
                  decoration-info="state == 'in_progress'"
                  decoration-warning="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'"
                  decoration-danger="is_auto_generated == True and state == 'draft'">
                <field name="name"/>
                <field name="product_id"/>
                <field name="qty_to_produce"/>
                <field name="qty_produced" readonly="1"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'in_progress'"
                       decoration-warning="state == 'confirmed'"/>
                <field name="work_center_id"/>
                <field name="scheduled_date"/>
                <field name="is_auto_generated" widget="boolean" string="Auto" optional="show"/>
                <field name="trigger_source" optional="show"/>
            </list>
        </field>
    </record>

    <!-- MO FORM -->
    <record id="view_shiv_mo_form" model="ir.ui.view">
        <field name="name">shiv.manufacturing.order.form</field>
        <field name="model">shiv.manufacturing.order</field>
        <field name="arch" type="xml">
            <form string="Manufacturing Order">
                <header>
                    <button name="action_start" string="Start Production"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state','!=','confirmed')]}"
                            confirm="Start production? Components will be consumed from inventory."/>
                    <button name="action_mark_done" string="Mark Done"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state','!=','in_progress')]}"
                            confirm="Mark complete? Finished goods will be added to inventory."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_progress,done"/>
                </header>
                <sheet>
                    <div class="alert alert-info"
                         attrs="{'invisible': [('is_auto_generated','=',False)]}">
                        <i class="fa fa-robot"/> Auto-generated by procurement engine.
                        Triggered by: <field name="trigger_source" readonly="1"/>
                    </div>
                    <group>
                        <group string="Production">
                            <field name="name" readonly="1"/>
                            <field name="product_id"
                                   attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="bom_id"
                                   attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="qty_to_produce"
                                   attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="qty_produced" readonly="1"/>
                        </group>
                        <group string="Scheduling">
                            <field name="work_center_id"
                                   attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="scheduled_date"
                                   attrs="{'readonly': [('state','!=','draft')]}"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Components">
                            <field name="component_line_ids" readonly="1" widget="one2many">
                                <list>
                                    <field name="product_id" string="Component"/>
                                    <field name="qty_required"/>
                                    <field name="qty_consumed" readonly="1"/>
                                    <field name="uom_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes"
                                   attrs="{'readonly': [('state','not in',['draft','confirmed'])]}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- MO SEARCH -->
    <record id="view_shiv_mo_search" model="ir.ui.view">
        <field name="name">shiv.manufacturing.order.search</field>
        <field name="model">shiv.manufacturing.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="product_id"/>
                <field name="work_center_id"/>
                <filter string="In Progress" name="filter_in_progress"
                        domain="[('state','=','in_progress')]"/>
                <filter string="Confirmed" name="filter_confirmed"
                        domain="[('state','=','confirmed')]"/>
                <filter string="Auto-Generated" name="filter_auto"
                        domain="[('is_auto_generated','=',True)]"/>
                <filter string="Done" name="filter_done"
                        domain="[('state','=','done')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="groupby_product"
                            context="{'group_by': 'product_id'}"/>
                    <filter string="Work Center" name="groupby_wc"
                            context="{'group_by': 'work_center_id'}"/>
                    <filter string="Status" name="groupby_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Scheduled Date" name="groupby_date"
                            context="{'group_by': 'scheduled_date:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_shiv_manufacturing_orders" model="ir.actions.act_window">
        <field name="name">Manufacturing Orders</field>
        <field name="res_model">shiv.manufacturing.order</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_in_progress': True}</field>
    </record>

</data></odoo>
