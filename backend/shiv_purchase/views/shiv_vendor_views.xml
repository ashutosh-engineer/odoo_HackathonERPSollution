<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_shiv_vendor_list" model="ir.ui.view">
        <field name="name">shiv.vendor.list</field>
        <field name="model">shiv.vendor</field>
        <field name="arch" type="xml">
            <tree string="Vendors" decoration-muted="not is_active">
                <field name="code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="reliability_score" widget="progressbar" options="{'max_value': 10}"/>
                <field name="on_time_delivery_pct"/>
                <field name="total_orders"/>
                <field name="is_active" optional="show"/>
            </tree>
        </field>
    </record>
    <record id="view_shiv_vendor_form" model="ir.ui.view">
        <field name="name">shiv.vendor.form</field>
        <field name="model">shiv.vendor</field>
        <field name="arch" type="xml">
            <form string="Vendor">
                <sheet>
                    <group>
                        <group string="Basic Info">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="gstin"/>
                            <field name="is_active"/>
                        </group>
                        <group string="Contact">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="address"/>
                        </group>
                    </group>
                    <group string="Performance">
                        <field name="reliability_score"/>
                        <field name="on_time_delivery_pct"/>
                        <field name="total_orders" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Products &amp; Pricing">
                            <field name="product_line_ids" widget="one2many">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="vendor_product_code"/>
                                    <field name="unit_price"/>
                                    <field name="min_order_qty"/>
                                    <field name="lead_time_days"/>
                                    <field name="is_preferred"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shiv_vendors" model="ir.actions.act_window">
        <field name="name">Vendors</field>
        <field name="res_model">shiv.vendor</field>
        <field name="view_mode">list,form</field>
    </record>
</data></odoo>
