<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_shiv_po_list" model="ir.ui.view">
        <field name="name">shiv.purchase.order.list</field>
        <field name="model">shiv.purchase.order</field>
        <field name="arch" type="xml">
            <list string="Purchase Orders"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'confirmed'"
                  decoration-muted="state == 'cancelled'"
                  decoration-info="is_auto_generated == True">
                <field name="name"/>
                <field name="vendor_id"/>
                <field name="state" widget="badge"/>
                <field name="date_order"/>
                <field name="date_expected"/>
                <field name="total_amount"/>
                <field name="is_auto_generated" widget="boolean" string="Auto"/>
                <field name="trigger_source" optional="show"/>
            </list>
        </field>
    </record>
    <record id="view_shiv_po_form" model="ir.ui.view">
        <field name="name">shiv.purchase.order.form</field>
        <field name="model">shiv.purchase.order</field>
        <field name="arch" type="xml">
            <form string="Purchase Order">
                <header>
                    <button name="action_confirm" string="Confirm Order"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state','!=','draft')]}"
                            groups="shiv_auth.group_shiv_purchase_manager"/>
                    <button name="action_receive" string="Mark Received"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state','not in',['confirmed','received'])]}"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('state','in',['done','cancelled'])]}"
                            confirm="Cancel this purchase order?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="alert alert-info" attrs="{'invisible': [('is_auto_generated','=',False)]}">
                        <i class="fa fa-robot"/> Auto-generated by procurement engine. Triggered by: <field name="trigger_source" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="vendor_id" attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="date_order" readonly="1"/>
                        </group>
                        <group>
                            <field name="date_expected" attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="total_amount" readonly="1"/>
                            <field name="confirmed_by" readonly="1"/>
                            <field name="confirmed_at" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids" attrs="{'readonly': [('state','!=','draft')]}" widget="one2many">
                        <list editable="bottom">
                            <field name="product_id"/>
                            <field name="qty_ordered"/>
                            <field name="qty_received" readonly="1"/>
                            <field name="unit_price"/>
                            <field name="subtotal" readonly="1"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="total_amount" readonly="1" class="oe_subtotal_footer_separator"/>
                    </group>
                    <field name="notes" attrs="{'readonly': [('state','!=','draft')]}"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_shiv_po_search" model="ir.ui.view">
        <field name="name">shiv.purchase.order.search</field>
        <field name="model">shiv.purchase.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/><field name="vendor_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="filter_confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Auto-Generated" name="filter_auto" domain="[('is_auto_generated','=',True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Vendor" name="groupby_vendor" context="{'group_by':'vendor_id'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_shiv_purchase_orders" model="ir.actions.act_window">
        <field name="name">Purchase Orders</field>
        <field name="res_model">shiv.purchase.order</field>
        <field name="view_mode">list,form</field>
    </record>
</data></odoo>
