<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <record id="rule_po_user_own" model="ir.rule">
        <field name="name">PO: Purchase User Sees Own Orders</field>
        <field name="model_id" ref="shiv_purchase.model_shiv_purchase_order"/>
        <field name="domain_force">[('create_uid','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_purchase_user'))]"/>
        <field name="perm_read">1</field><field name="perm_write">1</field>
        <field name="perm_create">1</field><field name="perm_unlink">0</field>
    </record>
    <record id="rule_po_manager_all" model="ir.rule">
        <field name="name">PO: Purchase Manager Sees All</field>
        <field name="model_id" ref="shiv_purchase.model_shiv_purchase_order"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_purchase_manager'))]"/>
        <field name="perm_read">1</field><field name="perm_write">1</field>
        <field name="perm_create">1</field><field name="perm_unlink">0</field>
    </record>
</data></odoo>
