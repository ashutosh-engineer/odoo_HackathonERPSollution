<?xml version="1.0" encoding="utf-8"?>
<odoo><data>

    <!-- Dashboard action — opens KPI summary via client action -->
    <record id="action_shiv_dashboard" model="ir.actions.client">
        <field name="name">Shiv ERP Dashboard</field>
        <field name="tag">shiv_dashboard</field>
        <field name="context">{}</field>
    </record>

    <!-- Fallback list action for environments without JS client action -->
    <record id="action_shiv_kpi_list" model="ir.actions.act_window">
        <field name="name">KPI Overview</field>
        <field name="res_model">shiv.kpi</field>
        <field name="view_mode">list</field>
        <field name="context">{'create': False}</field>
    </record>

</data></odoo>
