<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_shiv_category_list" model="ir.ui.view">
        <field name="name">shiv.product.category.list</field>
        <field name="model">shiv.product.category</field>
        <field name="arch" type="xml">
            <list string="Categories">
                <field name="complete_name"/>
                <field name="parent_id"/>
                <field name="product_count"/>
            </list>
        </field>
    </record>
    <record id="view_shiv_category_form" model="ir.ui.view">
        <field name="name">shiv.product.category.form</field>
        <field name="model">shiv.product.category</field>
        <field name="arch" type="xml">
            <form string="Product Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="parent_id"/>
                        <field name="product_count" readonly="1"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shiv_categories" model="ir.actions.act_window">
        <field name="name">Product Categories</field>
        <field name="res_model">shiv.product.category</field>
        <field name="view_mode">list,form</field>
    </record>
</data></odoo>
