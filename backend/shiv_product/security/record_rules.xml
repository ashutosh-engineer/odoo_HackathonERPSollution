<?xml version="1.0" encoding="utf-8"?>
<odoo><data noupdate="1">
    <!-- All authenticated users can read all active products -->
    <record id="rule_shiv_product_read_all" model="ir.rule">
        <field name="name">Product: All Users Read Active Products</field>
        <field name="model_id" ref="shiv_product.model_shiv_product"/>
        <field name="domain_force">[('is_active','=',True)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_viewer'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
    <!-- Admins see all including archived -->
    <record id="rule_shiv_product_admin_all" model="ir.rule">
        <field name="name">Product: Admin Sees All</field>
        <field name="model_id" ref="shiv_product.model_shiv_product"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('shiv_auth.group_shiv_admin'))]"/>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>
</data></odoo>
