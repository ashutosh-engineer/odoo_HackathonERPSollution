<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══ LIST VIEW ════════════════════════════════════════════════════ -->
        <record id="view_shiv_audit_log_list" model="ir.ui.view">
            <field name="name">shiv.audit.log.list</field>
            <field name="model">shiv.audit.log</field>
            <field name="arch" type="xml">
                <tree string="Audit Log" create="0" edit="0" delete="0"
                      decoration-danger="action in ['login_failed','account_locked','permission_denied','mfa_failed']"
                      decoration-warning="action in ['force_logout','force_password_reset','role_changed']"
                      decoration-success="action in ['login_success','create']"
                      decoration-info="action in ['write','password_changed']">
                    <field name="timestamp"/>
                    <field name="action" widget="badge"/>
                    <field name="actor_name"/>
                    <field name="actor_role"/>
                    <field name="model"/>
                    <field name="record_name"/>
                    <field name="changed_fields"/>
                    <field name="ip_address"/>
                    <field name="notes" optional="show"/>
                </tree>
            </field>
        </record>

        <!-- ═══ FORM VIEW ════════════════════════════════════════════════════ -->
        <record id="view_shiv_audit_log_form" model="ir.ui.view">
            <field name="name">shiv.audit.log.form</field>
            <field name="model">shiv.audit.log</field>
            <field name="arch" type="xml">
                <form string="Audit Log Entry" create="0" edit="0" delete="0">
                    <sheet>
                        <group string="Event">
                            <field name="timestamp" readonly="1"/>
                            <field name="action" readonly="1" widget="badge"/>
                            <field name="model" readonly="1"/>
                            <field name="record_id" readonly="1"/>
                            <field name="record_name" readonly="1"/>
                            <field name="changed_fields" readonly="1"/>
                        </group>
                        <group string="Actor">
                            <field name="actor_id" readonly="1"/>
                            <field name="actor_name" readonly="1"/>
                            <field name="actor_role" readonly="1"/>
                            <field name="ip_address" readonly="1"/>
                            <field name="session_token_preview" readonly="1"/>
                        </group>
                        <group string="Payload">
                            <field name="values_before" widget="code" readonly="1"
                                   attrs="{'invisible': [('values_before', '=', False)]}"/>
                            <field name="values_after" widget="code" readonly="1"
                                   attrs="{'invisible': [('values_after', '=', False)]}"/>
                            <field name="notes" readonly="1"/>
                        </group>
                        <group string="Immutability">
                            <field name="is_locked" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ═══ SEARCH VIEW ══════════════════════════════════════════════════ -->
        <record id="view_shiv_audit_log_search" model="ir.ui.view">
            <field name="name">shiv.audit.log.search</field>
            <field name="model">shiv.audit.log</field>
            <field name="arch" type="xml">
                <search string="Search Audit Logs">
                    <field name="actor_name"/>
                    <field name="model"/>
                    <field name="record_name"/>
                    <field name="ip_address"/>
                    <filter string="Today"
                            name="filter_today"
                            domain="[('timestamp', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                    <filter string="Security Events"
                            name="filter_security"
                            domain="[('action', 'in', ['login_failed','account_locked','permission_denied','force_logout','mfa_failed'])]"/>
                    <filter string="Login Events"
                            name="filter_logins"
                            domain="[('action', 'in', ['login_success','login_failed','logout'])]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Action"
                                name="groupby_action"
                                context="{'group_by': 'action'}"/>
                        <filter string="Actor"
                                name="groupby_actor"
                                context="{'group_by': 'actor_name'}"/>
                        <filter string="Model"
                                name="groupby_model"
                                context="{'group_by': 'model'}"/>
                        <filter string="Date"
                                name="groupby_date"
                                context="{'group_by': 'timestamp:day'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ═══ ACTION ═══════════════════════════════════════════════════════ -->
        <record id="action_shiv_audit_log" model="ir.actions.act_window">
            <field name="name">Audit Log</field>
            <field name="res_model">shiv.audit.log</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'create': False}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No audit log entries yet. All system events will appear here.
                </p>
            </field>
        </record>

        <!-- Security events shortcut -->
        <record id="action_shiv_security_events" model="ir.actions.act_window">
            <field name="name">Security Events</field>
            <field name="res_model">shiv.audit.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('action', 'in', ['login_failed','account_locked','permission_denied','force_logout','mfa_failed','role_changed'])]</field>
            <field name="context">{'create': False, 'search_default_filter_security': True}</field>
        </record>

    </data>
</odoo>
