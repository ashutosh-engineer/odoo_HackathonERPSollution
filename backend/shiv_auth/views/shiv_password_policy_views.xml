<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_shiv_password_policy_form" model="ir.ui.view">
            <field name="name">shiv.password.policy.form</field>
            <field name="model">shiv.password.policy</field>
            <field name="arch" type="xml">
                <form string="Password Policy">
                    <sheet>
                        <group>
                            <field name="policy_name"/>
                        </group>
                        <notebook>
                            <page string="Password Complexity">
                                <group>
                                    <field name="min_length"/>
                                    <field name="max_length"/>
                                    <field name="require_uppercase"/>
                                    <field name="require_lowercase"/>
                                    <field name="require_digit"/>
                                    <field name="require_special"/>
                                    <field name="special_chars_allowed"/>
                                </group>
                            </page>
                            <page string="Expiry &amp; History">
                                <group>
                                    <field name="expiry_days"/>
                                    <field name="history_depth"/>
                                    <field name="force_change_on_first_login"/>
                                </group>
                            </page>
                            <page string="Lockout &amp; Sessions">
                                <group>
                                    <field name="max_login_attempts"/>
                                    <field name="lockout_duration_minutes"/>
                                    <field name="max_concurrent_sessions"/>
                                    <field name="session_idle_timeout_hours"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_shiv_password_policy" model="ir.actions.act_window">
            <field name="name">Password Policy</field>
            <field name="res_model">shiv.password.policy</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
        </record>
    </data>
</odoo>
