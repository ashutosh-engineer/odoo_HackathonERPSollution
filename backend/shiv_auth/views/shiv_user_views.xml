<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ═══ FORM VIEW ═══════════════════════════════════════════════════ -->
        <record id="view_shiv_user_form" model="ir.ui.view">
            <field name="name">res.users.shiv.form</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='access_rights']" position="before">
                    <page string="Shiv ERP Profile" name="shiv_profile">
                        <group string="Role &amp; Department">
                            <field name="shiv_role"
                                   attrs="{'readonly': [('id', '!=', False), ('id', '!=', uid)]}"
                                   groups="shiv_auth.group_shiv_admin"/>
                            <field name="department"/>
                            <field name="employee_id"/>
                            <field name="phone_number"/>
                        </group>
                        <group string="Security Status">
                            <field name="is_mfa_enabled"/>
                            <field name="is_account_locked" readonly="1"/>
                            <field name="locked_until" readonly="1"
                                   attrs="{'invisible': [('is_account_locked', '=', False)]}"
                                   groups="shiv_auth.group_shiv_admin"/>
                            <field name="failed_login_count" readonly="1"
                                   groups="shiv_auth.group_shiv_admin"/>
                            <field name="must_change_password"
                                   groups="shiv_auth.group_shiv_admin"/>
                            <field name="is_password_expired" readonly="1"/>
                            <field name="password_expires_on" readonly="1"/>
                        </group>
                        <group string="Last Activity">
                            <field name="last_login" readonly="1"/>
                            <field name="last_login_ip" readonly="1"/>
                        </group>
                        <group string="Lifecycle" groups="shiv_auth.group_shiv_admin">
                            <field name="is_active_shiv" readonly="1"/>
                            <field name="deactivated_on" readonly="1"/>
                            <field name="deactivated_by" readonly="1"/>
                            <field name="deactivation_reason" readonly="1"/>
                        </group>
                        <group string="Audit" groups="shiv_auth.group_shiv_admin">
                            <field name="created_by_id" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="last_modified_by_id" readonly="1"/>
                            <field name="write_date" readonly="1"/>
                        </group>
                    </page>
                </xpath>

                <!-- Admin action buttons -->
                <xpath expr="//header" position="inside">
                    <button name="action_unlock_account"
                            string="Unlock Account"
                            type="object"
                            class="btn-warning"
                            attrs="{'invisible': [('is_account_locked', '=', False)]}"
                            groups="shiv_auth.group_shiv_admin"
                            confirm="Are you sure you want to unlock this account?"/>
                    <button name="action_force_password_reset"
                            string="Force Password Reset"
                            type="object"
                            class="btn-secondary"
                            groups="shiv_auth.group_shiv_admin"
                            confirm="This will force the user to change their password on next login."/>
                    <button name="action_deactivate_user"
                            string="Deactivate User"
                            type="object"
                            class="btn-danger"
                            attrs="{'invisible': [('active', '=', False)]}"
                            groups="shiv_auth.group_shiv_admin"
                            confirm="Deactivate this user? Their active sessions will be revoked."/>
                    <button name="action_reactivate_user"
                            string="Reactivate User"
                            type="object"
                            class="btn-success"
                            attrs="{'invisible': [('active', '=', True)]}"
                            groups="shiv_auth.group_shiv_admin"/>
                </xpath>
            </field>
        </record>

        <!-- ═══ LIST VIEW ════════════════════════════════════════════════════ -->
        <record id="view_shiv_user_list" model="ir.ui.view">
            <field name="name">res.users.shiv.list</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_tree"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="shiv_role"
                           widget="badge"
                           decoration-success="shiv_role in ['sales_manager','purchase_manager','warehouse_manager','production_manager']"
                           decoration-warning="shiv_role == 'viewer'"
                           decoration-danger="shiv_role == 'admin'"
                           decoration-info="shiv_role == 'auditor'"/>
                    <field name="department"/>
                    <field name="is_account_locked"
                           widget="boolean_toggle"
                           readonly="1"
                           optional="show"/>
                    <field name="last_login" optional="show"/>
                </field>
            </field>
        </record>

        <!-- ═══ SEARCH VIEW ══════════════════════════════════════════════════ -->
        <record id="view_shiv_user_search" model="ir.ui.view">
            <field name="name">res.users.shiv.search</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_search"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="shiv_role"/>
                    <field name="department"/>
                    <field name="employee_id"/>
                </field>
                <xpath expr="//search" position="inside">
                    <filter string="Locked Accounts"
                            name="filter_locked"
                            domain="[('is_account_locked', '=', True)]"/>
                    <filter string="Expired Passwords"
                            name="filter_expired_pwd"
                            domain="[('is_password_expired', '=', True)]"/>
                    <filter string="Must Change Password"
                            name="filter_must_change_pwd"
                            domain="[('must_change_password', '=', True)]"/>
                    <separator/>
                    <filter string="Admins"
                            name="filter_admins"
                            domain="[('shiv_role', '=', 'admin')]"/>
                    <filter string="Sales"
                            name="filter_sales"
                            domain="[('department', '=', 'sales')]"/>
                    <filter string="Warehouse"
                            name="filter_warehouse"
                            domain="[('department', '=', 'warehouse')]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Role"
                                name="groupby_role"
                                context="{'group_by': 'shiv_role'}"/>
                        <filter string="Department"
                                name="groupby_department"
                                context="{'group_by': 'department'}"/>
                    </group>
                </xpath>
            </field>
        </record>

        <!-- ═══ ACTION ═══════════════════════════════════════════════════════ -->
        <record id="action_shiv_users" model="ir.actions.act_window">
            <field name="name">Users</field>
            <field name="res_model">res.users</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'active_test': False}</field>
            <field name="domain">[('share', '=', False)]</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No users found. Create your first user.
                </p>
            </field>
        </record>

    </data>
</odoo>
