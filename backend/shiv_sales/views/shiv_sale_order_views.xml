<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_shiv_so_list" model="ir.ui.view">
        <field name="name">shiv.sale.order.list</field>
        <field name="model">shiv.sale.order</field>
        <field name="arch" type="xml">
            <tree string="Sales Orders"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'confirmed' and not is_fully_reserved"
                  decoration-danger="state == 'cancelled'"
                  decoration-info="procurement_triggered == True">
                <field name="name"/>
                <field name="customer_id"/>
                <field name="state" widget="badge"
                       decoration-success="state in ['delivered','done']"
                       decoration-warning="state == 'confirmed'"
                       decoration-info="state == 'picking'"/>
                <field name="date_order"/>
                <field name="delivery_date"/>
                <field name="total_amount"/>
                <field name="is_fully_reserved" widget="boolean" string="Reserved"/>
                <field name="procurement_triggered" widget="boolean" string="Proc." optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_shiv_so_form" model="ir.ui.view">
        <field name="name">shiv.sale.order.form</field>
        <field name="model">shiv.sale.order</field>
        <field name="arch" type="xml">
            <form string="Sales Order">
                <header>
                    <button name="action_confirm" string="Confirm &amp; Reserve Stock"
                            type="object" class="btn-primary"
                            attrs="{'invisible': [('state','!=','draft')]}"
                            confirm="Confirm order? This will reserve inventory (ACID lock). Cannot be undone easily."/>
                    <button name="action_deliver" string="Mark Delivered"
                            type="object" class="btn-success"
                            attrs="{'invisible': [('state','not in',['confirmed','picking'])]}"/>
                    <button name="action_cancel" string="Cancel"
                            type="object" class="btn-danger"
                            attrs="{'invisible': [('state','in',['delivered','done','cancelled'])]}"
                            confirm="Cancel this order? Reserved stock will be released."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,delivered,done"/>
                </header>
                <sheet>
                    <field name="is_fully_reserved" invisible="1"/>
                    <field name="procurement_triggered" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         attrs="{'invisible': ['|',('state','!=','confirmed'),('is_fully_reserved','=',True)]}">
                        <i class="fa fa-exclamation-triangle"/> Some items could not be reserved. Procurement has been triggered automatically.
                    </div>
                    <div class="alert alert-info" role="alert"
                         attrs="{'invisible': [('procurement_triggered','=',False)]}">
                        <i class="fa fa-cog fa-spin"/> Auto-procurement triggered for shortfall items. Check Procurement module.
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="customer_id" attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="date_order" readonly="1"/>
                        </group>
                        <group>
                            <field name="delivery_date" attrs="{'readonly': [('state','!=','draft')]}"/>
                            <field name="total_amount" readonly="1"/>
                            <field name="confirmed_by" readonly="1"/>
                            <field name="confirmed_at" readonly="1"/>
                        </group>
                    </group>
                    <field name="line_ids" attrs="{'readonly': [('state','!=','draft')]}" widget="one2many">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="qty_ordered"/>
                            <field name="unit_price"/>
                            <field name="discount_pct" groups="shiv_auth.group_shiv_sales_manager"/>
                            <field name="subtotal" readonly="1"/>
                            <field name="is_reserved" readonly="1" widget="boolean"/>
                        </tree>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="total_amount" readonly="1" class="oe_subtotal_footer_separator"/>
                    </group>
                    <field name="notes" attrs="{'readonly': [('state','!=','draft')]}"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shiv_so_search" model="ir.ui.view">
        <field name="name">shiv.sale.order.search</field>
        <field name="model">shiv.sale.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/><field name="customer_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Confirmed" name="filter_confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Not Fully Reserved" name="filter_not_reserved"
                        domain="[('is_fully_reserved','=',False),('state','=','confirmed')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="groupby_customer" context="{'group_by':'customer_id'}"/>
                    <filter string="Status" name="groupby_state" context="{'group_by':'state'}"/>
                    <filter string="Date" name="groupby_date" context="{'group_by':'date_order:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_shiv_sale_orders" model="ir.actions.act_window">
        <field name="name">Sales Orders</field>
        <field name="res_model">shiv.sale.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_shiv_customer_list" model="ir.ui.view">
        <field name="name">shiv.customer.list</field>
        <field name="model">shiv.customer</field>
        <field name="arch" type="xml">
            <tree string="Customers">
                <field name="name"/><field name="email"/>
                <field name="phone"/><field name="gstin"/>
                <field name="total_orders" readonly="1"/>
                <field name="total_revenue" readonly="1"/>
                <field name="credit_limit"/>
            </tree>
        </field>
    </record>
    <record id="view_shiv_customer_form" model="ir.ui.view">
        <field name="name">shiv.customer.form</field>
        <field name="model">shiv.customer</field>
        <field name="arch" type="xml">
            <form string="Customer">
                <sheet>
                    <group>
                        <group><field name="name"/><field name="gstin"/><field name="is_active"/></group>
                        <group><field name="email"/><field name="phone"/><field name="credit_limit"/></group>
                    </group>
                    <field name="address"/>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_shiv_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">shiv.customer</field>
        <field name="view_mode">list,form</field>
    </record>
</data></odoo>
